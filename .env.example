# PostgreSQL (requis en local et sur Vercel)
# Ex. Neon : https://neon.tech | Vercel Postgres : dashboard Vercel → Storage | Supabase : Settings → Database
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
# Avec Supabase : optionnel. URL directe (port 5432) pour prisma migrate deploy au build Vercel. Si absent, DATABASE_URL est utilisée.
# DIRECT_URL="postgresql://user:password@db.xxx.supabase.co:5432/postgres"

NEXTAUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3001"
# En production : NEXTAUTH_URL="https://votre-app.vercel.app"

# Optionnel : secret pour sécuriser l’appel au job de relances (cron)
# CRON_SECRET="votre-secret"

# Envoi de factures par email au client (Resend) — https://resend.com
# RESEND_API_KEY="re_..."
# RESEND_FROM="factures@votredomaine.com"  # optionnel, domaine vérifié dans Resend

# Générateur de documents droit familial (IA) — révision humaine obligatoire
# ANTHROPIC_API_KEY="sk-ant-..."
