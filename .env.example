# PostgreSQL (requis en local et sur Vercel)
# Ne laissez pas de ligne "DIRECT_URL=" vide : supprimez-la ou renseignez une URL valide.

# --- Supabase (recommandé) ---
# 1) Dashboard Supabase → Project Settings → Database
# 2) Connection string → Mode "URI" ou "Prisma"
#
# Pooler (transaction), port 6543 — à utiliser comme DATABASE_URL pour l'app / Prisma client :
#   postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
#
# Connexion directe (session), port 5432 — pour DIRECT_URL (migrations Prisma, introspection) :
#   postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require
#   ou : postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require
#
# Si le mot de passe contient des caractères spéciaux (@, #, etc.), encodez-les en URL (ex. @ → %40).
# Projet Supabase en pause : reprenez-le dans le dashboard (Resume project).
# Réseau : le pooler utilise le port 6543 (sortant autorisé depuis votre machine / Vercel).

DATABASE_URL="postgresql://user:password@host:6543/postgres?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres?sslmode=require"

# --- Autres hébergeurs (Neon, etc.) ---
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
# DIRECT_URL peut être identique à DATABASE_URL si une seule URL suffit.

NEXTAUTH_SECRET="generate-a-secret-with-openssl-rand-base64-48"
NEXTAUTH_URL="http://localhost:3001"
# En production : NEXTAUTH_URL="https://votre-app.vercel.app"

# Optionnel : secret pour sécuriser l'appel au job de relances (cron)
# CRON_SECRET="votre-secret"

# --- Stripe (facturation SaaS) ---
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Email (Resend) ---
# RESEND_API_KEY="re_..."
# EMAIL_FROM="SAFE <noreply@votre-domaine.com>"

# --- IA ---
# Générateur de documents droit familial (IA) — révision humaine obligatoire
# ANTHROPIC_API_KEY="sk-ant-..."

# --- OpenAI (transcription vocale agents) ---
# OPENAI_API_KEY="sk-..."

# Optionnel : vidéo de fond du hero landing (HLS .m3u8 ou MP4). Vide = dégradés uniquement.
# Pour HLS depuis un autre domaine, le serveur doit autoriser CORS pour les segments.
# NEXT_PUBLIC_HERO_VIDEO_URL="https://exemple.com/stream/master.m3u8"
