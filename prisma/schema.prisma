// ========== Journal général (registre central, append-only) ==========

enum JournalTransactionType {
  FACTURE
  PAIEMENT
  DEPOT_FIDEICOMMIS
  RETRAIT_FIDEICOMMIS
  DEBOURS
  DEPENSE
  AJUSTEMENT
  CORRECTION
}

enum JournalSourceModule {
  FACTURATION
  PAIEMENTS
  FIDEICOMMIS
  DEPENSES
  DEBOURS
  IMPORT_BANCAIRE
  AJUSTEMENT_MANUEL
  CORRECTION_SYSTEME
}

/// Journal général — append-only.
///
/// Idempotence structurelle: un index UNIQUE PARTIEL est maintenu hors-Prisma
/// sur (cabinetId, sourceModule, sourceId) WHERE sourceId IS NOT NULL.
/// Cf. migration `20260429120000_add_journal_idempotency_unique_index`.
///
/// Conséquences à respecter pour toute évolution de ce modèle :
///   - tout INSERT avec sourceId non null pour un triplet déjà présent → P2002.
///   - les lignes sans sourceId (ajustements manuels libres) restent autorisées.
///   - aucune mutation rétroactive: les corrections passent par une nouvelle
///     ligne `typeTransaction = CORRECTION`.
model JournalGeneralEntry {
  id              String                 @id @default(cuid())
  cabinetId       String
  dateTransaction DateTime
  typeTransaction JournalTransactionType
  reference       String?
  clientId        String?
  dossierId       String?
  description     String
  categorie       String?
  montantEntree   Float                  @default(0)
  montantSortie   Float                  @default(0)
  solde           Float                  @default(0)
  sourceModule    JournalSourceModule
  sourceId        String?
  utilisateurId   String?
  createdAt       DateTime               @default(now())

  cabinet     Cabinet  @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  dossier     Dossier? @relation(fields: [dossierId], references: [id], onDelete: SetNull)
  utilisateur User?    @relation(fields: [utilisateurId], references: [id], onDelete: SetNull)

  @@index([cabinetId])
  @@index([cabinetId, dateTransaction])
  @@index([cabinetId, typeTransaction])
  @@index([clientId])
  @@index([dossierId])
  @@index([sourceModule])
  @@index([cabinetId, clientId, dateTransaction])
  @@map("journal_general")
}

