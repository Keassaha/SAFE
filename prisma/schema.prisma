// --- Module A: Vérification d'identité, documents, audit, consentement ---

enum IdentityVerificationStatus {
  en_attente
  verifie
  refuse
}

model ClientIdentityVerification {
  id         String                     @id @default(cuid())
  clientId   String
  date       DateTime
  methode    String // pièce d'identité, vidéo, etc.
  statut     IdentityVerificationStatus @default(en_attente)
  documentId String? // référence optionnelle vers Document (preuve)
  notes      String?
  createdAt  DateTime                   @default(now())
  updatedAt  DateTime                   @updatedAt

  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  document Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([clientId])
}

model Document {
  id                        String    @id @default(cuid())
  cabinetId                 String
  clientId                  String?
  dossierId                 String?
  documentType              String? // depot_tribunal, contrat, correspondance, preuve, etc.
  nom                       String
  mimeType                  String
  sizeBytes                 Int
  storageKey                String // chemin ou clé objet (fichier local ou S3)
  hash                      String? // intégrité
  uploadedById              String
  retentionJusqua           DateTime?
  sectionKey                String? // section de cartable suggérée/confirmée
  classificationSubtype     String?
  classificationConfidence  Int?
  classificationNeedsReview Boolean   @default(false)
  classificationReason      String?
  // Générateur droit familial : type template (taxonomie), assistance IA, révision humaine
  templateCode              String? // code taxonomie (ex. demande_divorce_contestee, formulaire_annexe_i)
  aiAssisted                Boolean?  @default(false)
  reviewedAt                DateTime?
  reviewedById              String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  cabinet               Cabinet                      @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  client                Client?                      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dossier               Dossier?                     @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  uploadedBy            User                         @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  reviewedBy            User?                        @relation("DocumentReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  identityVerifications ClientIdentityVerification[]
  docketEntries         DossierDocketEntry[]

  @@index([cabinetId])
  @@index([clientId])
  @@index([dossierId])
  @@index([cabinetId, dossierId])
  @@index([cabinetId, dossierId, sectionKey])
  @@index([templateCode])
}

model AuditLog {
  id          String    @id @default(cuid())
  cabinetId   String
  userId      String?
  entityType  String
  entityId    String
  action      String
  metadata    String? // JSON (legacy)
  oldValues   String? // JSON
  newValues   String? // JSON
  performedBy String?
  performedAt DateTime?
  ip          String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  cabinet Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([cabinetId])
  @@index([cabinetId, entityType])
  @@index([cabinetId, createdAt])
  @@index([entityType, entityId])
}

// --- Module Facturation (billing) ---

model Expense {
  id            String        @id @default(cuid())
  cabinetId     String
  clientId      String
  matterId      String?
  expenseDate   DateTime
  description   String
  vendorName    String?
  amount        Float
  taxable       Boolean       @default(false)
  recoverable   Boolean       @default(true)
  billingStatus BillingStatus @default(NON_BILLED)
  invoiceId     String?
  invoiceLineId String?
  receiptUrl    String?
