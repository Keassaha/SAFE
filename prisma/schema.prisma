  cabinetId String
  cabinet   Cabinet  @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  dossierId String?
  dossier   Dossier? @relation(fields: [dossierId], references: [id], onDelete: SetNull)
  clientId  String?

  type    String // "status_change" | "closing_reminder" | "ircc_update" | "document_expiry"
  channel String @default("email") // "email" | "sms"

  sentAt  DateTime @default(now())
  sentTo  String // email address
  subject String
  status  String   @default("sent") // "sent" | "failed" | "bounced"

  metadata String? // JSON: { oldStatus, newStatus, closingDate, etc. }

  @@index([cabinetId])
  @@index([dossierId])
  @@index([cabinetId, sentAt])
}

/// Signal "dossier prêt pour revue avocat".
///
/// Doctrine: docs/product/READY_FOR_REVIEW_SIGNAL.md
///
/// Un signal est créé quand un dossier passe à l'état dérivé `pret_pour_revue`
/// suite à une action de l'assistante. Il est destiné à l'avocat responsable
/// (ou aux admin du cabinet quand aucun avocat n'est assigné).
///
/// Déduplication structurelle: index UNIQUE PARTIEL `(dedupeKey) WHERE "readAt" IS NULL`,
/// maintenu hors-Prisma via la migration `20260429180000_add_ready_for_review_signal`.
/// Tant que le signal n'est pas marqué lu, on ne peut pas en créer un second
/// pour la même clé `(dossierId, avocatResponsableId)`.
model DossierReadyForReviewSignal {
  id                  String    @id @default(cuid())
  cabinetId           String
  dossierId           String
  clientId            String
  avocatResponsableId String?
  createdById         String?
  reason              String? // ex: "preparation_complete"
  /// Clé canonique pour la déduplication: `${dossierId}:${avocatResponsableId ?? "no_avocat"}`.
  dedupeKey           String
  createdAt           DateTime  @default(now())
  readAt              DateTime?
  acknowledgedById    String?

  cabinet           Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  dossier           Dossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  client            Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  avocatResponsable User?   @relation("ReadyForReviewSignalAvocat", fields: [avocatResponsableId], references: [id], onDelete: SetNull)
  createdBy         User?   @relation("ReadyForReviewSignalCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  acknowledgedBy    User?   @relation("ReadyForReviewSignalAcknowledgedBy", fields: [acknowledgedById], references: [id], onDelete: SetNull)

  @@index([cabinetId, readAt])
  @@index([cabinetId, avocatResponsableId, readAt])
  @@index([dossierId])
}

/// Cahier structuré du dossier.
///
/// Doctrine: docs/product/PRACTICE_BRIEFCASE_AND_DOCKET_SYSTEM.md
///
/// Le cahier adapte sa lecture à la pratique:
/// - `procedure` pour famille / protection / criminel
/// - `suivi` pour immigration
/// - `transaction` pour immobilier
///
/// Une entrée peut provenir d'un document importé, d'un document riche ou d'une
/// saisie manuelle future. Les imports créent seulement des entrées pour les
/// documents significatifs, avec revue humaine lorsque la confiance est faible.
model DossierDocketEntry {
  id                   String    @id @default(cuid())
  cabinetId            String
  clientId             String
  dossierId            String
  entryType            String
  docketMode           String
  title                String
  status               String    @default("a_reviser")
  eventDate            DateTime?
  sequenceNumber       Int       @default(0)
  sectionKey           String
  linkedDocumentId     String?
  linkedRichDocumentId String?
  source               String    @default("manual")
  confidence           Int?
  needsReview          Boolean   @default(true)
  notes                String?
  metadata             String?
  createdById          String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  cabinet            Cabinet       @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  client             Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dossier            Dossier       @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  linkedDocument     Document?     @relation(fields: [linkedDocumentId], references: [id], onDelete: SetNull)
  linkedRichDocument RichDocument? @relation(fields: [linkedRichDocumentId], references: [id], onDelete: SetNull)

  @@index([cabinetId])
  @@index([cabinetId, dossierId])
  @@index([cabinetId, dossierId, docketMode])
  @@index([linkedDocumentId])
  @@index([linkedRichDocumentId])
}

// --- Facturation par étape (B4) ---
model DossierBillingStage {
  id        String  @id @default(cuid())
  dossierId String
  dossier   Dossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)

  nom         String // "Preparation", "Submission", "Follow-up"
  ordre       Int
  montant     Float
  pourcentage Float? // e.g. 50, 25, 25

  statut    String   @default("pending") // "pending" | "ready" | "invoiced"
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  invoicedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dossierId])
  @@index([dossierId, ordre])
}

// --- Templates de débours attendus par type de dossier (B6) ---
model DeboursTemplate {
  id            String  @id @default(cuid())
  cabinetId     String
  dossierType   String // "immobilier", "immigration", "immobilier_condo", etc.
  deboursTypeId String
  isRequired    Boolean @default(false) // true = bloquant, false = suggestion

  deboursType DeboursType @relation(fields: [deboursTypeId], references: [id], onDelete: Cascade)

  @@unique([cabinetId, dossierType, deboursTypeId])
  @@index([cabinetId, dossierType])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 1 — ATELIER DE RÉDACTION
// ─────────────────────────────────────────────────────────────────────────────

// Document riche créé dans l'éditeur Tiptap (distinct du model Document = fichiers uploadés)
model RichDocument {
  id          String @id @default(cuid())
  cabinetId   String
  dossierId   String
  clientId    String
  createdById String

  titre   String
  content String @default("{}") // JSON Tiptap/ProseMirror
  type    String @default("note") // "note" | "lettre" | "contrat" | "procedure" | "requete" | "autre"
  statut  String @default("brouillon") // "brouillon" | "final" | "archive"

  // Conformité Barreau — jamais de suppression réelle
  isArchived   Boolean   @default(false)
  archivedAt   DateTime?
  archivedById String?

  // Métadonnées utiles
  lastEditedById String?
  lastEditedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cabinet      Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  dossier      Dossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  client       Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy    User    @relation("RichDocCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  lastEditedBy User?   @relation("RichDocLastEditedBy", fields: [lastEditedById], references: [id], onDelete: SetNull)
  archivedBy   User?   @relation("RichDocArchivedBy", fields: [archivedById], references: [id], onDelete: SetNull)

  versions      RichDocumentVersion[]
  workSessions  WorkSession[]
  docketEntries DossierDocketEntry[]

  @@index([cabinetId])
  @@index([dossierId])
  @@index([cabinetId, dossierId])
  @@index([cabinetId, statut])
}

// Historique des versions — immutable, audit trail Barreau
model RichDocumentVersion {
  id             String @id @default(cuid())
  richDocumentId String
  cabinetId      String
  createdById    String

  content       String // Snapshot JSON du contenu Tiptap
  versionNumber Int
  label         String? // "Version initiale", "Après révision client", etc.
  hash          String? // SHA-256 du contenu pour intégrité

  createdAt DateTime @default(now())

  richDocument RichDocument @relation(fields: [richDocumentId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([richDocumentId])
  @@index([cabinetId])
}

// Session de travail chrono — créée quand l'avocat clique "Terminé"
// Génère automatiquement une TimeEntry
model WorkSession {
  id             String  @id @default(cuid())
  cabinetId      String
  userId         String
  dossierId      String
  clientId       String
  richDocumentId String? // null si session manuelle (hors éditeur)

  startedAt    DateTime
  endedAt      DateTime?
  dureeMinutes Int? // calculé à la fermeture

  typeActivite String  @default("redaction") // "redaction" | "revision" | "consultation" | "recherche" | "autre"
  description  String? // pré-remplie IA ou saisie manuelle

  statut String @default("en_cours") // "en_cours" | "pause" | "termine"

  // Lien vers la fiche de temps créée automatiquement
  timeEntryId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cabinet      Cabinet       @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  dossier      Dossier       @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  richDocument RichDocument? @relation(fields: [richDocumentId], references: [id], onDelete: SetNull)
  timeEntry    TimeEntry?    @relation(fields: [timeEntryId], references: [id], onDelete: SetNull)

  @@index([cabinetId])
  @@index([userId])
  @@index([dossierId])
  @@index([cabinetId, statut])
}

// ========== Invitations équipe ==========

model Invitation {
  id           String    @id @default(cuid())
  cabinetId    String
  createdById  String
  email        String
  role         UserRole
  token        String    @unique
  expiresAt    DateTime
  acceptedAt   DateTime?
  compensation String? // JSON: { type, montant, isBillable, tauxHoraireFact, visibleRentabilite, saisieParEmployee }
  createdAt    DateTime  @default(now())

  cabinet Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)

  @@index([cabinetId])
  @@index([token])
}
