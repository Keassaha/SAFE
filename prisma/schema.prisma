// --- Rapprochement fidéicommis (By-Law 9 / B-1 r.5) ---
model TrustReconciliation {
  id        String  @id @default(cuid())
  cabinetId String
  cabinet   Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)

  periode String // "2026-04" (YYYY-MM)

  // Données 3-way reconciliation
  soldeBancaire        Float // Solde selon relevé bancaire
  chequesEnCirculation Float @default(0) // Chèques émis non encaissés
  depotsEnTransit      Float @default(0) // Dépôts non encore crédités
  soldeRapproche       Float // soldeBancaire - chequesEnCirculation + depotsEnTransit
  soldeRegistre        Float // Somme transactions SAFE (source de vérité)
  soldeParDossier      Float // Somme TrustAccount.currentBalance
  ecart                Float @default(0) // soldeRapproche - soldeRegistre (doit être 0)

  // Certification par l'avocat
  certifiedAt   DateTime?
  certifiedById String?
  certifiedBy   User?     @relation("ReconciliationCertifiedBy", fields: [certifiedById], references: [id], onDelete: SetNull)

  // Intérêts Law Foundation of Ontario / Barreau
  interetsLFO     Float     @default(0)
  interetsPayesAt DateTime?

  status String  @default("draft") // "draft" | "complete" | "certified"
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  complianceReports TrustComplianceReport[]

  @@unique([cabinetId, periode])
  @@index([cabinetId])
  @@index([cabinetId, status])
}

// --- Rapport conformité fidéicommis (PDF exportable) ---
model TrustComplianceReport {
  id        String  @id @default(cuid())
  cabinetId String
  cabinet   Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)

  periode       String // "2026-04"
  type          String   @default("monthly") // "monthly" | "quarterly" | "annual"
  generatedAt   DateTime @default(now())
  generatedById String
  generatedBy   User     @relation("ComplianceReportGeneratedBy", fields: [generatedById], references: [id], onDelete: SetNull)

  pdfUrl String? // URL Supabase Storage
  status String  @default("draft") // "draft" | "final"
  data   String? // JSON: snapshot transactions

  reconciliationId String?
  reconciliation   TrustReconciliation? @relation(fields: [reconciliationId], references: [id], onDelete: SetNull)

  @@index([cabinetId])
  @@index([cabinetId, periode])
}

// --- Déclaration antécédents immigration (D7) ---
