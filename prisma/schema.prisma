  carte
  virement
  cheque
  trust
  autre
}

enum TrustTransactionType {
  deposit
  withdrawal
  correction
}

enum TrustModePaiement {
  CHEQUE
  VIREMENT
  INTERAC
  ESPECES
  AUTRE
}

model Invoice {
  id                     String                @id @default(cuid())
  cabinetId              String
  clientId               String
  dossierId              String?
  numero                 String
  dateEmission           DateTime
  dateEcheance           DateTime
  statut                 InvoiceStatut         @default(brouillon)
  invoiceStatus          InvoiceStatusBilling? @default(DRAFT)
  montantTotal           Float                 @default(0)
  montantPaye            Float                 @default(0)
  subtotalTaxable        Float                 @default(0)
  tps                    Float                 @default(0)
  tvq                    Float                 @default(0)
  deboursNonTaxableTotal Float                 @default(0)
  trustApplied           Float                 @default(0)
  balanceDue             Float                 @default(0)
  tauxInteret            Float?
  dateLimiteInterets     DateTime?
  lastReminderDay        Int?
  lastInterestAppliedAt  DateTime?
  validatedAt            DateTime?
  validatedById          String?
  currency               String?               @default("CAD")
  subtotalFees           Float                 @default(0)
  subtotalExpenses       Float                 @default(0)
  subtotalAdjustments    Float                 @default(0)
  subtotalInterest       Float                 @default(0)
  subtotalBeforeTax      Float                 @default(0)
  taxGst                 Float                 @default(0)
  taxQst                 Float                 @default(0)
  taxTotal               Float                 @default(0)
  trustAppliedAmount     Float                 @default(0)
  creditAppliedAmount    Float                 @default(0)
  totalInvoiceAmount     Float                 @default(0)
  totalPaidAmount        Float                 @default(0)
  interestAccrued        Float                 @default(0)
  paymentStatus          PaymentStatus?        @default(UNPAID)
  issueMethod            IssueMethod?
  billingGroupKey        String?
  clientNote             String?
  internalNote           String?
  sentAt                 DateTime?
  approvedAt             DateTime?
  approvedById           String?
  cancelledAt            DateTime?
  cancelReason           String?
  createdById            String?
  shareToken             String?               @unique // token pour lien unique d'envoi au client
  shareTokenExpiresAt    DateTime? // expiration du lien (option config cabinet)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  cabinet                Cabinet                 @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  client                 Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dossier                Dossier?                @relation(fields: [dossierId], references: [id], onDelete: SetNull)
  validatedBy            User?                   @relation(fields: [validatedById], references: [id], onDelete: SetNull)
  invoiceItems           InvoiceItem[]
  invoiceLines           InvoiceLine[]
  payments               Payment[]
  paymentAllocations     PaymentAllocation[]
  reminderLogs           InvoiceReminder[]
  sendLogs               InvoiceSendLog[]
  expenses               Expense[]
  timeEntries            TimeEntry[]
  creditNotes            CreditNote[]
  creditNoteApplications CreditNoteApplication[]
  interestCharges        InterestCharge[]
  deboursDossiers        DeboursDossier[]
  trustTransactions      TrustTransaction[]
  billingStages          DossierBillingStage[]

  @@unique([cabinetId, numero])
  @@index([cabinetId])
  @@index([cabinetId, statut])
  @@index([clientId])
  @@index([dossierId])
  @@index([validatedById])
  @@index([invoiceStatus])
  @@index([paymentStatus])
}

model InvoiceLine {
  id                String                 @id @default(cuid())
  invoiceId         String
  timeEntryId       String?
  description       String
  quantite          Float
  tauxUnitaire      Float
  montant           Float
  lineType          InvoiceLineType?       @default(fee)
  sourceType        InvoiceLineSourceType? @default(manual)
  sourceId          String?
  matterId          String?
  serviceDate       DateTime?
  lineSubtotal      Float?
  taxable           Boolean                @default(true)
  gstAmount         Float                  @default(0)
  qstAmount         Float                  @default(0)
  lineTotal         Float?
  sortOrder         Int                    @default(0)
  validationComment String? // instructions / commentaires par ligne pour la page de validation
  // Rabais canoniques (cf. doctrine refonte facturation phase 1) :
  // - parentLineId pointe sur la ligne d'honoraires/débours rabattue (self-relation).
  // - discountReason est la raison libre affichable au client (ex. "Courtoisie professionnelle").
  // Une ligne de rabais a typiquement lineType="adjustment" et un montant négatif.
  parentLineId      String?
  discountReason    String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @default(now()) @updatedAt

  invoice         Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  timeEntry       TimeEntry?       @relation("TimeEntryAsSource", fields: [timeEntryId], references: [id], onDelete: SetNull)
  matter          Dossier?         @relation(fields: [matterId], references: [id], onDelete: SetNull)
  timeEntryRef    TimeEntry?       @relation("InvoiceLineRef")
  expenses        Expense[]
  deboursDossier  DeboursDossier?  @relation("DeboursDossierInvoiceLine")
  registreTache   RegistreTache?   @relation("RegistreTacheInvoiceLine")
  interestCharges InterestCharge[]
  rabaisItems     InvoiceItem[]
  parentLine      InvoiceLine?     @relation("InvoiceLineDiscount", fields: [parentLineId], references: [id], onDelete: SetNull)
  discountLines   InvoiceLine[]    @relation("InvoiceLineDiscount")

  @@index([invoiceId])
  @@index([timeEntryId])
  @@index([matterId])
  @@index([parentLineId])
}

model InvoiceItem {
  id                      String          @id @default(cuid())
  invoiceId               String
  type                    InvoiceItemType
  description             String
  date                    DateTime
  hours                   Float? // pour honoraires (durée en heures)
  rate                    Float? // pour honoraires (taux horaire)
  amount                  Float
  userId                  String? // professionnel pour honoraires
  professionalDisplayName String? // nom affiché si différent de user
  timeEntryId             String?
  parentItemId            String? // pour rabais : ligne d'honoraire (InvoiceItem) parente
  parentLineId            String? // pour rabais : ligne d'honoraire (InvoiceLine) parente
  validationComment       String? // instructions / commentaires par ligne pour la validation
  createdAt               DateTime        @default(now())

  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  timeEntry     TimeEntry?    @relation(fields: [timeEntryId], references: [id], onDelete: SetNull)
  parentItem    InvoiceItem?  @relation("RabaisParentItem", fields: [parentItemId], references: [id], onDelete: Cascade)
  rabaisEnfants InvoiceItem[] @relation("RabaisParentItem")
  parentLine    InvoiceLine?  @relation(fields: [parentLineId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([type])
  @@index([parentItemId])
  @@index([parentLineId])
}

model Payment {
  id                String                @id @default(cuid())
  cabinetId         String
  clientId          String? // requis pour nouveaux paiements; dérivé de facture si absent
  invoiceId         String?
  montant           Float
  datePaiement      DateTime
  mode              String?
  method            PaymentMethod         @default(autre)
  reference         String?
  paymentMethod     PaymentMethodBilling? @default(other)
  referenceNumber   String?
  sourceAccountType SourceAccountType?    @default(operating)
  allocationStatus  AllocationStatus      @default(UNALLOCATED)
  note              String?
  receivedById      String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @default(now()) @updatedAt

  cabinet            Cabinet             @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  client             Client?             @relation(fields: [clientId], references: [id], onDelete: SetNull)
  invoice            Invoice?            @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  paymentAllocations PaymentAllocation[]

  @@index([cabinetId])
  @@index([clientId])
  @@index([invoiceId])
  @@index([allocationStatus])
}

model PaymentAllocation {
  id              String   @id @default(cuid())
  paymentId       String
  invoiceId       String
  allocatedAmount Float
  allocatedAt     DateTime @default(now())
  createdAt       DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([invoiceId])
}

enum InvoiceReminderType {
  rappel_only // J+5, J+15 : email rappel uniquement
  frais // J+10 : 5$ frais + envoi facture + écriture dossier
  frais_et_interets // J+20, J+30... : 5$ + intérêts 14%/an + envoi + écriture
}

model InvoiceReminder {
  id             String               @id @default(cuid())
  invoiceId      String
  reminderDay    Int? // 5, 10, 15, 20, 30, 40...
  type           InvoiceReminderType?
  reminderType   ReminderType? // reminder_1, reminder_2, final_notice, interest_notice
  scheduledAt    DateTime?
  sentAt         DateTime?
  status         String?
  channel        ReminderChannel? // email, manual, printed
  amountFrais    Float?
  amountInterets Float?
  note           String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([invoiceId, sentAt])
}

// Trace d'envoi initial d'une facture officielle (séparé de InvoiceReminder qui couvre les relances).
// Une entrée par tentative d'envoi : succès comme échec. Source de vérité de l'historique d'envoi
// affiché dans la fiche client et l'éditeur de facture.
model InvoiceSendLog {
  id             String   @id @default(cuid())
  invoiceId      String
  cabinetId      String
  clientId       String
  dossierId      String?
  sentById       String?
  recipientEmail String
  subject        String
  body           String?
  status         String   @default("sent") // "sent" | "failed" | "queued"
  errorMessage   String?
  pdfUrl         String?
  attachmentName String?
  attachmentSize Int?
  sentAt         DateTime?
  createdAt      DateTime @default(now())

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  cabinet Cabinet  @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  client  Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dossier Dossier? @relation(fields: [dossierId], references: [id], onDelete: SetNull)
  sentBy  User?    @relation(fields: [sentById], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([cabinetId])
  @@index([clientId])
  @@index([dossierId])
  @@index([invoiceId, createdAt])
}

model TrustAccount {
  id             String   @id @default(cuid())
  cabinetId      String
  clientId       String
  matterId       String?
  currentBalance Float    @default(0)
  currency       String   @default("CAD")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  cabinet      Cabinet            @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  client       Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  matter       Dossier?           @relation(fields: [matterId], references: [id], onDelete: SetNull)
  transactions TrustTransaction[]

  @@unique([cabinetId, clientId, matterId])
  @@index([cabinetId])
  @@index([clientId])
  @@index([matterId])
}

model TrustTransaction {
  id              String                       @id @default(cuid())
  cabinetId       String
  trustAccountId  String?
  clientId        String
  dossierId       String?
  date            DateTime
  amount          Float
  type            TrustTransactionType
  transactionType TrustTransactionTypeBilling?
  balanceAfter    Float?
  invoiceId       String?
  note            String?
  description     String?
  reference       String?
  modePaiement    TrustModePaiement?
  correctionOfId  String?
  createdById     String?
  createdAt       DateTime                     @default(now())

  cabinet      Cabinet            @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  trustAccount TrustAccount?      @relation(fields: [trustAccountId], references: [id], onDelete: SetNull)
  client       Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dossier      Dossier?           @relation(fields: [dossierId], references: [id], onDelete: SetNull)
  invoice      Invoice?           @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  correctionOf TrustTransaction?  @relation("TrustCorrection", fields: [correctionOfId], references: [id], onDelete: SetNull)
  corrections  TrustTransaction[] @relation("TrustCorrection")

  @@index([cabinetId])
  @@index([trustAccountId])
  @@index([clientId])
  @@index([dossierId])
  @@index([date])
  @@index([cabinetId, clientId, dossierId, date])
}

model CreditNote {
  id               String           @id @default(cuid())
  cabinetId        String
  clientId         String
  invoiceId        String
