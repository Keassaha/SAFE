// --- Registre de tâches forfaitaires (par dossier) ---
model RegistreTache {
  id        String  @id @default(cuid())
  cabinetId String
  cabinet   Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  dossierId String
  dossier   Dossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  clientId  String?

  forfaitServiceId String?
  forfaitService   ForfaitService? @relation(fields: [forfaitServiceId], references: [id], onDelete: SetNull)

  description  String // pré-remplie depuis ForfaitService.nom, modifiable
  montantBase  Float // prix catalogue au moment de l'ajout
  ajustement   Float   @default(0) // +/- ajustement de prix
  rabais       Float   @default(0) // montant du rabais
  rabaisRaison String? // raison du rabais (affichée sur facture)
  montantFinal Float // montantBase + ajustement - rabais
  taxable      Boolean @default(true)

  date   DateTime @default(now())
  statut String   @default("complete") // "en_cours" | "complete" | "facture"

  invoiceLineId String?      @unique
  invoiceLine   InvoiceLine? @relation("RegistreTacheInvoiceLine", fields: [invoiceLineId], references: [id], onDelete: SetNull)

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([cabinetId])
  @@index([dossierId])
  @@index([cabinetId, statut])
  @@index([dossierId, statut])
}

// --- Notifications client (COM1, COM2) ---
model NotificationLog {
