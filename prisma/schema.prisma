generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Cabinet {
  id                     String    @id @default(cuid())
  nom                    String
  adresse                String?
  telephone              String?
  email                  String?
  logoUrl                String?
  barreauNumero          String? // LSO#, Barreau# for invoice header
  config                 String? // JSON: tauxInteret, devise, formatFacture
  plan                   String    @default("essentiel")
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeSubscriptionStatus String?
  stripeCurrentPeriodEnd DateTime?
  stripeCancelAtPeriodEnd Boolean   @default(false)
  stripeTrialEnd         DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  users                      User[]
  clients                    Client[]
  dossiers                   Dossier[]
  timeEntries                TimeEntry[]
  expenses                   Expense[]
  invoices                   Invoice[]
  invoiceSendLogs            InvoiceSendLog[]
  payments                   Payment[]
  documents                  Document[]
  auditLogs                  AuditLog[]
  documentRetentionPolicies  DocumentRetentionPolicy[]
  trustAccounts              TrustAccount[]
  trustTransactions          TrustTransaction[]
  billingRuns                BillingRun[]
  creditNotes                CreditNote[]
  deboursTypes               DeboursType[]
  deboursDossiers            DeboursDossier[]
  expenseCategories          ExpenseCategory[]
  bankImportSessions         BankImportSession[]
  bankImportTransactions     BankImportTransaction[]
  expenseCategorizationRules ExpenseCategorizationRule[]
  cabinetExpenses            CabinetExpense[]
  journalEntries             JournalGeneralEntry[]
  employees                  Employee[]
  payrollPeriods             PayrollPeriod[]
  importHistories            ImportHistory[]
  calendarEvents             CalendarEvent[]
  dossierTrustMovements      DossierTrustMovement[]
  dossierReminders           DossierReminder[]
  auditSubmissions           AuditSubmission[]
  interfaceConfig            CabinetInterface?
  trustReconciliations       TrustReconciliation[]
  trustComplianceReports     TrustComplianceReport[]
  notificationLogs           NotificationLog[]
  forfaitServices            ForfaitService[]
  registreTaches             RegistreTache[]
  richDocuments              RichDocument[]
  workSessions               WorkSession[]
  dossierSections            DossierSection[]
  invitations                Invitation[]
  readyForReviewSignals      DossierReadyForReviewSignal[]
  stripeWebhookEvents        StripeWebhookEvent[]
  dossierDocketEntries       DossierDocketEntry[]
}

enum UserRole {
  admin_cabinet
  avocat
  assistante
  comptabilite
}

model User {
  id                String   @id @default(cuid())
  cabinetId         String
  email             String
  passwordHash      String
  nom               String
  role              UserRole
  defaultHourlyRate Float?
  isBillable        Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  cabinet                    Cabinet                 @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  timeEntries                TimeEntry[]
  dossiersResponsable        Dossier[]               @relation("AvocatResponsable")
  dossiersAssistantJuridique Dossier[]               @relation("AssistantJuridiqueDossier")
  documentsUploaded          Document[]
  documentsReviewed          Document[]              @relation("DocumentReviewedBy")
  auditLogs                  AuditLog[]
  consentLogsRecorded        ConsentLog[]
  clientsLawyerInCharge      Client[]                @relation("LawyerInCharge")
  clientsAssignedLawyer      Client[]                @relation("AssignedLawyer")
  clientsAssistantAssigned   Client[]                @relation("AssistantAssigned")
  dossierTachesAssignees     DossierTache[]
  dossierActesAssignees      DossierActe[]
  dossierNotesCreated        DossierNote[]
  invoiceItems               InvoiceItem[]
  invoicesValidated          Invoice[] // factures validées par cet utilisateur
  invoiceSendLogs            InvoiceSendLog[]
  timeEntriesApproved        TimeEntry[]             @relation("TimeEntryApprovedBy")
  bankImportSessionsCreated  BankImportSession[]
  cabinetExpensesCreated     CabinetExpense[]
  journalEntriesCreated      JournalGeneralEntry[]
  employee                   Employee?
  importHistories            ImportHistory[]
  calendarEventsAssigned     CalendarEvent[]         @relation("CalendarEventAssignee")
  calendarEventsCreated      CalendarEvent[]         @relation("CalendarEventCreator")
  mandateResponsable         DossierMandate[]        @relation("MandateAvocatResponsable")
  mandateSubstitut           DossierMandate[]        @relation("MandateAvocatSubstitut")
  trustMovementsValidated    DossierTrustMovement[]  @relation("TrustMovementValidatedBy")
  dossierClosuresClosed      DossierClosure[]        @relation("DossierClosureClosedBy")
  reconciliationsCertified   TrustReconciliation[]   @relation("ReconciliationCertifiedBy")
  complianceReportsGenerated TrustComplianceReport[] @relation("ComplianceReportGeneratedBy")
  conflictChecksPerformed    ConflictCheck[]         @relation("ConflictCheckPerformedBy")

  // Signaux "dossier prêt pour revue" — voir docs/product/READY_FOR_REVIEW_SIGNAL.md
  readyForReviewSignalsAsAvocat     DossierReadyForReviewSignal[] @relation("ReadyForReviewSignalAvocat")
  readyForReviewSignalsCreated      DossierReadyForReviewSignal[] @relation("ReadyForReviewSignalCreatedBy")
  readyForReviewSignalsAcknowledged DossierReadyForReviewSignal[] @relation("ReadyForReviewSignalAcknowledgedBy")

  resetToken       String?
  resetTokenExpiry DateTime?

  // Phase 1 — Atelier de Rédaction
  richDocsCreated  RichDocument[]        @relation("RichDocCreatedBy")
  richDocsEdited   RichDocument[]        @relation("RichDocLastEditedBy")
  richDocsArchived RichDocument[]        @relation("RichDocArchivedBy")
  richDocVersions  RichDocumentVersion[]
  workSessions     WorkSession[]
}

enum EmployeeRole {
  ADMIN_ACCOUNTANT
  LEAD_LAWYER
  LAWYER
  LEGAL_ASSISTANT
  ACCOUNTING_TECHNICIAN
  INTERN
  READ_ONLY
}

enum EmployeeStatus {
  active
  inactive
}

enum PayrollFrequency {
  weekly
}

enum PayrollPeriodStatus {
  draft
  closed
}

enum PayslipStatus {
  draft
  generated
  paid
}

enum PayslipAdjustmentType {
  bonus
  deduction
  correction
}

model Employee {
  id               String         @id @default(cuid())
  cabinetId        String
  userId           String?        @unique
  firstName        String
  lastName         String
  fullName         String
  email            String
  phone            String?
  address          String?
  hireDate         DateTime
  status           EmployeeStatus @default(active)
  role             EmployeeRole
  jobTitle         String?
  hourlyRate       Float          @default(0)
  supervisorId     String?
  responsibilities String? // assigned responsibilities / workflow
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  cabinet      Cabinet    @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  supervisor   Employee?  @relation("EmployeeSupervisor", fields: [supervisorId], references: [id], onDelete: SetNull)
  subordinates Employee[] @relation("EmployeeSupervisor")
  payslips     Payslip[]

  @@index([cabinetId])
  @@index([cabinetId, status])
  @@index([userId])
  @@index([supervisorId])
}

model PayrollPeriod {
  id          String              @id @default(cuid())
  cabinetId   String
  periodStart DateTime
  periodEnd   DateTime
  frequency   PayrollFrequency    @default(weekly)
  status      PayrollPeriodStatus @default(draft)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  cabinet  Cabinet   @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  payslips Payslip[]

  @@index([cabinetId])
  @@index([cabinetId, periodStart])
}

model Payslip {
  id              String        @id @default(cuid())
  employeeId      String
  payrollPeriodId String
  hoursWorked     Float         @default(0)
  hourlyRate      Float
  grossPay        Float         @default(0)
  deductions      Float         @default(0)
  netPay          Float         @default(0)
  status          PayslipStatus @default(draft)
  paymentDate     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  employee    Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  period      PayrollPeriod       @relation(fields: [payrollPeriodId], references: [id], onDelete: Cascade)
  adjustments PayslipAdjustment[]

  @@index([employeeId])
  @@index([payrollPeriodId])
}

model PayslipAdjustment {
  id          String                @id @default(cuid())
  payslipId   String
  type        PayslipAdjustmentType
  amount      Float
  description String?
  createdAt   DateTime              @default(now())

  payslip Payslip @relation(fields: [payslipId], references: [id], onDelete: Cascade)

  @@index([payslipId])
}

enum TypeClient {
  personne_physique
  personne_morale
}

enum ClientStatus {
  actif
  inactif
  archive
}

enum PreferredContactMethod {
  email
  phone
  mail
}

enum IdType {
  passport
  driver_license
  other
}

enum RepresentationType {
  plaintiff
  defendant
  advisor
}

enum PreferredPaymentMethod {
  card
  transfer
  trust
  cheque
}

model Client {
  id                          String                  @id @default(cuid())
  cabinetId                   String
  typeClient                  TypeClient              @default(personne_morale)
  status                      ClientStatus            @default(actif)
  raisonSociale               String?
  prenom                      String?
  nom                         String?
  dateNaissance               DateTime?
  numeroRegistreEntreprise    String?
  contact                     String?
  email                       String?
  emailSecondaire             String?
  telephone                   String?
  telephoneSecondaire         String?
  adresse                     String?
  addressLine1                String?
  addressLine2                String?
  city                        String?
  province                    String?
  postalCode                  String?
  country                     String?
  preferredContactMethod      PreferredContactMethod?
  langue                      String? // FR, EN
  nas                         String?
  consentementCollecteAt      DateTime?
  finalitesConsentement       String?
  dateVerificationIdentite    DateTime?
  methodeVerificationIdentite String?
  idType                      IdType?
  idNumber                    String?
  idExpiration                DateTime?
  identityVerified            Boolean                 @default(false)
  verificationDate            DateTime?
  retentionJusqua             DateTime?
  notesConfidentielles        String?
  lawyerInChargeId            String?
  assignedLawyerId            String?
  assistantAssignedId         String?
  representationType          RepresentationType?
  retainerSigned              Boolean                 @default(false)
  retainerDate                DateTime?
  trustAccountBalance         Float                   @default(0)
  trustAccountId              String?
  allowTrustPayments          Boolean                 @default(false)
  lastTrustTransactionDate    DateTime?
  billingContactName          String?
  billingEmail                String?
  billingAddress              String?
  paymentTerms                String?
  preferredPaymentMethod      PreferredPaymentMethod?
  creditLimit                 Float?
  clientCode                  String?
  displayName                 String?
  billingAddressLine1         String?
  billingAddressLine2         String?
  billingCity                 String?
  billingProvince             String?
  billingPostalCode           String?
  billingCountry              String?
  languagePreference          String?
  paymentTermsDays            Int?
  defaultInterestRateAnnual   Float?
  isActive                    Boolean                 @default(true)
  conflictChecked             Boolean                 @default(false)
  conflictCheckDate           DateTime?
  conflictNotes               String?
  documentRefs                String? // JSON: retainer_agreement, id_documents, court_documents, client_correspondence
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime                @updatedAt

  cabinet               Cabinet                       @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  lawyerInCharge        User?                         @relation("LawyerInCharge", fields: [lawyerInChargeId], references: [id], onDelete: SetNull)
  assignedLawyer        User?                         @relation("AssignedLawyer", fields: [assignedLawyerId], references: [id], onDelete: SetNull)
  assistantAssigned     User?                         @relation("AssistantAssigned", fields: [assistantAssignedId], references: [id], onDelete: SetNull)
  dossiers              Dossier[]
  timeEntries           TimeEntry[]
  expenses              Expense[]
  invoices              Invoice[]
  invoiceSendLogs       InvoiceSendLog[]
  documents             Document[]
  trustAccounts         TrustAccount[]
  trustTransactions     TrustTransaction[]
  identityVerifications ClientIdentityVerification[]
  consentLogs           ConsentLog[]
  payments              Payment[]
  creditNotes           CreditNote[]
  billingRuns           BillingRun[]
  deboursDossiers       DeboursDossier[]
  journalEntries        JournalGeneralEntry[]
  calendarEvents        CalendarEvent[]               @relation("CalendarEventClient")
  richDocuments         RichDocument[]
  workSessions          WorkSession[]
  readyForReviewSignals DossierReadyForReviewSignal[]
  dossierDocketEntries  DossierDocketEntry[]

  @@index([cabinetId])
  @@index([cabinetId, raisonSociale])
  @@index([cabinetId, status])
  @@index([assignedLawyerId])
}

enum DossierStatut {
  ouvert
  actif
  en_attente
  cloture
  archive
}

enum DossierType {
  droit_famille
  litige_civil
  criminel
  immigration
  immobilier
  corporate
  autre
}

enum ModeFacturationDossier {
  horaire
  forfait
  retainer
  contingent
}

model Dossier {
  id                        String                  @id @default(cuid())
  cabinetId                 String
  clientId                  String
  avocatResponsableId       String?
  assistantJuridiqueId      String?
  reference                 String?
  numeroDossier             String?
  matterCode                String?
  intitule                  String
  statut                    DossierStatut           @default(actif)
  type                      DossierType?
  descriptionConfidentielle String?
  resumeDossier             String?
  notesStrategieJuridique   String?
  tribunalNom               String?
  districtJudiciaire        String?
  numeroDossierTribunal     String?
  nomJuge                   String?
  modeFacturation           ModeFacturationDossier?
  tauxHoraire               Float?
  soldeFiducieDossier       Float?                  @default(0)
  autoriserPaiementFiducie  Boolean                 @default(false)
  dateOuverture             DateTime                @default(now())
  dateCloture               DateTime?
  retentionJusqua           DateTime?

  // Immobilier-specific fields (D2)
  sousType            String? // "achat" | "vente" | "condo" | "hypotheque" | "ee" | "parrainage" | "travail" | "appel"
  closingDate         DateTime?
  propertyAddress     String?
  fintracVerified     Boolean   @default(false)
  fintracVerifiedAt   DateTime?
  fintracVerifiedById String?
  fintracDocuments    String? // JSON: { doc1: "type", doc2: "type" }
  condoPINParking     String?
  condoPINLocker      String?

  // Immigration-specific fields (D3)
  irccStatut         String? // "consultation" | "preparation" | "soumission" | "biometrie" | "suivi" | "decision" | "cloture"
  irccNumDossier     String? // IRCC application number
  itaDate            DateTime? // Date ITA reçu (Express Entry — 60j deadline)
  submissionDeadline DateTime? // Calculé auto: itaDate + 60j
  cnpCode            String? // National Occupation Classification
  cnpValidated       Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cabinet               Cabinet                       @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  client                Client                        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  avocatResponsable     User?                         @relation("AvocatResponsable", fields: [avocatResponsableId], references: [id], onDelete: SetNull)
  assistantJuridique    User?                         @relation("AssistantJuridiqueDossier", fields: [assistantJuridiqueId], references: [id], onDelete: SetNull)
  timeEntries           TimeEntry[]
  expenses              Expense[]
  documents             Document[]
  taches                DossierTache[]
  evenements            DossierEvenement[]
  actesLexTrack         DossierActe[]
  notes                 DossierNote[]
  invoices              Invoice[]
  invoiceSendLogs       InvoiceSendLog[]
  trustAccounts         TrustAccount[]
  trustTransactions     TrustTransaction[]
  invoiceLines          InvoiceLine[]
  deboursDossiers       DeboursDossier[]
  cabinetExpenses       CabinetExpense[]
  journalEntries        JournalGeneralEntry[]
  calendarEvents        CalendarEvent[]               @relation("CalendarEventDossier")
  clientInfo            DossierClientInfo?
  mandate               DossierMandate?
  pieces                DossierPiece[]
  procedures            DossierProcedure[]
  judgments             DossierJudgment[]
  correspondence        DossierCorrespondence[]
  trustMovements        DossierTrustMovement[]
  closure               DossierClosure?
  reminders             DossierReminder[]
  immigrationBackground ImmigrationBackground?
  immigrationDocuments  ImmigrationDocument[]
  conflictChecks        ConflictCheck[]
  notificationLogs      NotificationLog[]
  billingStages         DossierBillingStage[]
  registreTaches        RegistreTache[]
  richDocuments         RichDocument[]
  workSessions          WorkSession[]
  sections              DossierSection[]
  readyForReviewSignals DossierReadyForReviewSignal[]
  docketEntries         DossierDocketEntry[]

  @@unique([cabinetId, numeroDossier])
  @@index([cabinetId])
  @@index([cabinetId, clientId])
  @@index([cabinetId, statut])
  @@index([cabinetId, type])
  @@index([avocatResponsableId])
  @@index([assistantJuridiqueId])
}

model DossierClientInfo {
  id                  String    @id @default(cuid())
  dossierId           String    @unique
  nasEncrypted        String?
  dateNaissance       DateTime? @db.Date
  regimeMatrimonial   String?
  dateMariage         DateTime? @db.Date
  dateSeparation      DateTime? @db.Date
  statutMatrimonial   String?
  enfants             Json?
  situationFinanciere Json?
  identiteCoordonnees Json?
  situationFamiliale  Json?
  updatedAt           DateTime  @updatedAt

  dossier Dossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)

  @@index([dossierId])
}

model DossierMandate {
  id                   String    @id @default(cuid())
  dossierId            String    @unique
  numeroDossier        String?   @unique
  dateOuverture        DateTime?
  avocatResponsableId  String?
  avocatSubstitutId    String?
  typeCause            String?
  districtJudiciaire   String?
  tribunal             String?
  numeroRole           String?
  estimationHonoraires Decimal?  @db.Decimal(12, 2)
  provisionInitiale    Decimal?  @db.Decimal(12, 2)
  statutDossier        String?
  checklist            Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  dossier           Dossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  avocatResponsable User?   @relation("MandateAvocatResponsable", fields: [avocatResponsableId], references: [id], onDelete: SetNull)
  avocatSubstitut   User?   @relation("MandateAvocatSubstitut", fields: [avocatSubstitutId], references: [id], onDelete: SetNull)

  @@index([dossierId])
}

model DossierPiece {
  id            String    @id @default(cuid())
  dossierId     String
  partie        String
  numero        String
  titre         String
  description   String?
  categorie     String?
  statut        String    @default("Manquant")
  dateReception DateTime? @db.Date
  fichierUrl    String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  dossier Dossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)

  @@index([dossierId])
  @@index([dossierId, partie])
}

model DossierProcedure {
  id                String    @id @default(cuid())
  dossierId         String
  typeProcedure     String
  description       String?
  dateDepot         DateTime? @db.Date
  dateSignification DateTime? @db.Date
  statut            String    @default("À déposer")
  fichierUrl        String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  dossier Dossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)

  @@index([dossierId])
}

model DossierJudgment {
  id              String    @id @default(cuid())
  dossierId       String
  typeJugement    String
  dispositions    String?
  dateJugement    DateTime? @db.Date
  dateLimiteAppel DateTime? @db.Date
  statutAppel     String?   @default("En cours")
  fichierUrl      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  dossier Dossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)

  @@index([dossierId])
}

model DossierCorrespondence {
  id                String    @id @default(cuid())
  dossierId         String
  typeCommunication String
  titre             String?
  expediteur        String?
  destinataire      String?
  dateCommunication DateTime? @db.Date
  fichierUrl        String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  dossier Dossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)

  @@index([dossierId])
}

model DossierTrustMovement {
  id            String    @id @default(cuid())
  dossierId     String
  cabinetId     String
  amount        Decimal   @db.Decimal(12, 2)
  direction     String
  typeMouvement String?
  description   String?
  status        String    @default("PENDING")
  validatedById String?
  validatedAt   DateTime?
  createdAt     DateTime  @default(now())

  dossier     Dossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  cabinet     Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  validatedBy User?   @relation("TrustMovementValidatedBy", fields: [validatedById], references: [id], onDelete: SetNull)

  @@index([dossierId])
  @@index([cabinetId])
}

model DossierClosure {
  id              String    @id @default(cuid())
  dossierId       String    @unique
  checklist       Json?
  closedById      String?
  closedAt        DateTime?
  destructionDate DateTime? @db.Date
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  dossier  Dossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  closedBy User?   @relation("DossierClosureClosedBy", fields: [closedById], references: [id], onDelete: SetNull)

  @@index([dossierId])
}

model DossierReminder {
  id        String   @id @default(cuid())
  dossierId String?
  cabinetId String
  type      String?
  message   String?
  dueDate   DateTime @db.Date
  isSent    Boolean  @default(false)
  createdAt DateTime @default(now())

  dossier Dossier? @relation(fields: [dossierId], references: [id], onDelete: SetNull)
  cabinet Cabinet  @relation(fields: [cabinetId], references: [id], onDelete: Cascade)

  @@index([dossierId])
  @@index([cabinetId])
}

model DossierSection {
  id                  String   @id @default(cuid())
  dossierId           String
  cabinetId           String
  sectionKey          String // maps to UI component: "mandat" | "formulaires" | "procedures" | etc.
  label               String
  ordre               Int
  origine             String   @default("template") // "template" | "user"
  sourceReglementaire String?
  icone               String? // lucide icon name
  description         String?
  privilegiee         Boolean  @default(false)
  archive             Boolean  @default(false)
  createdAt           DateTime @default(now())

  dossier Dossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  cabinet Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)

  @@index([dossierId])
  @@index([cabinetId])
}

model DossierNote {
  id           String   @id @default(cuid())
  dossierId    String
  createdById  String?
  typeNote     String?
  content      String
  confidentiel Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  dossier   Dossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  createdBy User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([dossierId])
  @@index([createdById])
}

enum DossierTachePriorite {
  low
  medium
  high
  urgent
}

enum DossierTacheStatut {
  a_faire
  en_cours
  terminee
  annulee
}

model DossierTache {
  id           String               @id @default(cuid())
  dossierId    String
  titre        String
  description  String?
  assigneeId   String?
  priorite     DossierTachePriorite @default(medium)
  statut       DossierTacheStatut   @default(a_faire)
  dateEcheance DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  dossier  Dossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  assignee User?   @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([dossierId])
  @@index([assigneeId])
}

enum DossierEvenementType {
  audience
  reunion_client
  echeance
  depot
  relance_facture
}

model DossierEvenement {
  id        String               @id @default(cuid())
  dossierId String
  type      DossierEvenementType
  titre     String
  date      DateTime
  lieu      String?
  notes     String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  dossier Dossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)

  @@index([dossierId])
  @@index([dossierId, date])
}

// --- LexTrack : gestion de dossier type « tableau de production » (strips par avocat, phases procédurales) ---

enum LexTrackPhase {
  INSTRUCTION
  MISE_EN_ETAT
  PLAIDOIRIES
  DELIBERE
}

enum LexTrackActeType {
  analyse
  acte
  recherche
  admin
  audience
  echeance
}

enum LexTrackActeStatut {
  todo
  inprogress
  upcoming
  done
}

enum LexTrackPriorite {
  basse
  moyenne
  haute
  critique
}

model DossierActe {
  id          String             @id @default(cuid())
  dossierId   String
  assigneeId  String
  phase       LexTrackPhase
  type        LexTrackActeType
  status      LexTrackActeStatut @default(todo)
  priority    LexTrackPriorite   @default(moyenne)
  title       String
  description String?
  deadline    DateTime
  tags        String? // JSON array: ["stratégie", "dépôt", "tribunal", ...]
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  dossier  Dossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  assignee User    @relation(fields: [assigneeId], references: [id], onDelete: Cascade)

  @@index([dossierId])
  @@index([assigneeId])
  @@index([dossierId, phase])
  @@index([dossierId, assigneeId])
}

enum TimeEntryStatut {
  brouillon
  valide
  facture
}

enum BillingStatus {
  NON_BILLED
  READY_TO_BILL
  IN_DRAFT_INVOICE
  BILLED
  NON_BILLABLE
  WRITTEN_OFF
  CANCELLED
}

model TimeEntry {
  id             String          @id @default(cuid())
  cabinetId      String
  dossierId      String?
  clientId       String?
  userId         String
  date           DateTime
  dureeMinutes   Int
  description    String?
  typeActivite   String?
  facturable     Boolean         @default(true)
  statut         TimeEntryStatut @default(brouillon)
  tauxHoraire    Float
  montant        Float
  workDate       DateTime?
  startTime      DateTime?
  endTime        DateTime?
  durationHours  Float?
  internalNote   String?
  hourlyRate     Float?
  feeAmount      Float?
  taxable        Boolean         @default(true)
  billingStatus  BillingStatus?  @default(NON_BILLED)
  invoiceId      String?
  invoiceLineId  String?         @unique
  isWrittenOff   Boolean         @default(false)
  writeOffReason String?
  approvedById   String?
  approvedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  cabinet      Cabinet       @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  dossier      Dossier?      @relation(fields: [dossierId], references: [id], onDelete: SetNull)
  client       Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice      Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  invoiceLine  InvoiceLine?  @relation("InvoiceLineRef", fields: [invoiceLineId], references: [id], onDelete: SetNull)
  invoiceLines InvoiceLine[] @relation("TimeEntryAsSource")
  invoiceItems InvoiceItem[]
  approvedBy   User?         @relation("TimeEntryApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  workSession  WorkSession?

  @@index([cabinetId])
  @@index([cabinetId, dossierId])
  @@index([cabinetId, clientId])
  @@index([cabinetId, date])
  @@index([cabinetId, userId])
  @@index([cabinetId, statut])
  @@index([billingStatus])
  @@index([invoiceId])
}

enum InvoiceStatut {
